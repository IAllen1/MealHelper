<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.ShoppingList.ShoppingListDetails">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAddIngredientToList"
        android:layout_width="404dp"
        android:layout_height="63dp"
        android:layout_marginBottom="6dp"
        android:background="#D5C8C8"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintBottom_toTopOf="@+id/shoppingIngredientRecyclerView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:menu="@menu/shopping_list_add"
        app:title="Placeholder" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/shoppingIngredientRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbarAddIngredientToList" />
</androidx.constraintlayout.widget.ConstraintLayout>